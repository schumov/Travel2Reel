PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me-dev-secret-with-16-plus-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# Claude AI
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Redis caching
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Image processing
IMAGE_MAX_SIZE_MB=2
IMAGE_COMPRESSION_QUALITY=80
IMAGE_STRIP_EXIF=true
IMAGE_AUTO_ROTATE=true

# Guest session
GUEST_COOKIE_SECRET=change-me-guest-secret-with-16-plus-chars
GUEST_SESSION_EXPIRY_DAYS=90
GUEST_INACTIVITY_EXPIRY_DAYS=30

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=May2026

# OpenStreetMap request identity
OSM_REFERER=https://meineseite.de
OSM_USER_AGENT=MeineApp/1.0 (https://meineseite.de; kontakt@meineseite.de)
