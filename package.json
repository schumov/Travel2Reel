{
  "name": "travel2reel",
  "version": "1.0.0",
  "description": "Travel2Reel – video generation accelerator for your travel",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "echo \"No tests configured yet\"",
    "prisma:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma",
    "prisma:generate:sqlserver": "prisma generate --schema prisma/schema.sqlserver.prisma",
    "prisma:db:push:sqlite": "prisma db push --schema prisma/schema.sqlite.prisma",
    "prisma:db:push:sqlserver": "prisma db push --schema prisma/schema.sqlserver.prisma",
    "postinstall": "npm run prisma:generate:sqlite",
    "prebuild": "npm run prisma:generate:sqlite"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@prisma/client": "^6.19.3",
    "@types/fluent-ffmpeg": "^2.1.28",
    "dotenv": "^17.4.2",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "leaflet": "^1.9.4",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "^6.19.3",
    "puppeteer": "^24.40.0",
    "redis": "^5.11.0",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/sharp": "^0.31.1",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
